#endif

#if 1
	samsung,ub-con-det = <SEC_GPIO_REF(AP,tlmm,19) 0>;
#endif

#if 1
	samsung,esd-irq-gpio1 = <SEC_GPIO_REF(AP,tlmm,35) 0>; /* DISP_DET */
#endif

#if 0
	samsung,esd-irq-gpio2 = <SEC_GPIO_REF(${panel_esd_2_gpio}) 0>; /* ERR_FG */
#endif

#if 0
	qcom,panel-sec-supply-entries
#else
	qcom,panel-supply-entries
#endif
	{
		#address-cells = <1>;
		#size-cells = <0>;

		/* display on: 1.8V -> 1ms -> 5.5V & -5.5V on -> 10ms -> reset high -> LP11
		 * -> reset low -> 3ms -> reset high -> 10ms -> display config 1 cmds
		 * -> 10ms -> sleep in cmd -> 100ms -> display on cmd
		 */
		/* display off: 'FFh 10h' and 'FBh 01h' cmds -> display off cmd -> 20ms
		* -> sleep in -> lp11 -> 60ms -> reset low -> -5.5V  & 5.5V off-> 1ms ->  vddi off
		*/
		qcom,panel-supply-entry@0 {
			reg = <0>;
			qcom,supply-name = "lcd_vddi"; /* VDD 1.8V */
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <1>;
			qcom,supply-post-off-sleep = <32>;
		};

		qcom,panel-supply-entry@1 {
			reg = <1>;
			qcom,supply-name = "lcd_vsp";
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <2>;
			qcom,supply-post-off-sleep = <4>;
		};
		qcom,panel-supply-entry@2 {
			reg = <2>;
			qcom,supply-name = "lcd_vsn";
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <13>;
			qcom,supply-post-off-sleep = <2>;
		};

#if 1
		qcom,panel-supply-entry@4 {
			reg = <4>;
			qcom,supply-name = "lcd_rst";
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <10>;
			qcom,supply-post-off-sleep = <1>;
		};
#endif
	};
};

