	ft820x_tsp_cs_active: ft820x_tsp_cs_active {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,3, FUNC_OUTPUT_HIGH, PULL_NONE, DRV_LV3);
	};
	ft820x_tsp_cs_sleep: ft820x_tsp_cs_sleep {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,3, FUNC_OUTPUT_LOW, PULL_DOWN, DRV_LV3);
	};
};

&qupv3_se0_spi {
	num-cs = <2>;
	cs-gpios = <SEC_GPIO_REF(AP,tlmm,3) 0>, <SEC_GPIO_REF(AP,tlmm,3) 0>;
};

&tsp_focaltech {
	pinctrl-0 = <&ft820x_tsp_int_active &ft820x_tsp_rst_active &ft820x_tsp_cs_active>;
	pinctrl-1 = <&ft820x_tsp_int_sleep &ft820x_tsp_rst_sleep &ft820x_tsp_cs_sleep>;

	focaltech,display-coords = <0 0 1080 2408>;

	sec,lcdid1-gpio = <&pm6125_gpios 2 0x0>;
	sec,lcdid2-gpio = <&pm6125_gpios 8 0x0>;
	sec,lcdid3-gpio = <&pm6125_gpios 9 0x0>;
	sec,lcdid = <6>;
	sec,lcdtype = <0 0 0 0 0 0 0x4b1270>;

	sec,firmware_name = "", "", "", "", "", "", "tsp_focaltech/ft8720_a23.bin";
	focaltech,ramtest_name = "tsp_focaltech/ft8720_a23_ramtest.bin";

	sec,name_lcd_rst = "lcd_rst";
	sec,name_lcd_vddi = "lcd_vddi";
	sec,name_lcd_bl_en = "lcd_bl_en";
	sec,name_lcd_vsp = "lcd_vsp";
	sec,name_lcd_vsn = "lcd_vsn";

	enable_settings_aot;
	prox_lp_scan_enabled;
	scan_off_when_cover_closed;
	enable_vbus_notifier;
};

&soc {
	ss_touch {
		compatible = "samsung,ss_touch";
		ss_touch,numbers = <1>;
	};
};

