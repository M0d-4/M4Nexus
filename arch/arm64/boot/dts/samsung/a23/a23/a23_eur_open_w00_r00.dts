	nfc_clk_req_gpio: nfc_clk_req_gpio {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,71, FUNC_INPUT, PULL_DOWN, DRV_LV3);
	};
	nfc_irq_gpio: nfc_irq_gpio {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,70, FUNC_INPUT, PULL_DOWN, DRV_LV3);
	};
	nfc_ven_gpio: nfc_ven_gpio {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,69, FUNC_OUTPUT_HIGH, PULL_NONE, DRV_LV3);
	};
	nfc_firm_gpio: nfc_firm_gpio {
