/* #include "../../sec_thermistor.dtsi" */           /* From sec_thermistor.py */
&smd {
	sec_ap_thermistor: sec_thermistor@0 {
		compatible = "samsung,sec-thermistor";
		status = "okay";
		thermistor_name = "sec-ap-thermistor";
		id = <0>;

		io-channels = SEC_ADC(pm6125_vadc,0x52);
		io-channel-names = "ap_therm";
		io-channel-ranges;
	};
};

&pm6125_vadc {
	ap_therm {
		reg = SEC_ADC_NUM(pm6125_vadc,0x52);
		label = "ap_therm";
		qcom,ratiometric;
		qcom,hw-settle-time = <200>;
		qcom,pre-scaling = <1 1>;

#if 0
		/* Set calib type to ADC_SCALE_HW_CALIB_DEFAULT */
		qcom,scale-fn-type = <5>;
#else
		qcom,decimation = <840>;
		qcom,avg-samples = <8>;
#endif
	};
};
