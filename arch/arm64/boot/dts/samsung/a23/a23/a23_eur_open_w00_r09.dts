				};

				config {
					pins = "gpio32", "gpio33";
					bias-pull-down;
					drive-strength = <0x2>;
				};
			};

			storage_cmd_on {
				phandle = <0x2a>;

				config {
					pins = "sdc2_cmd";
					bias-pull-up;
					drive-strength = <0xc>;
				};
			};

			storage_data_on {
