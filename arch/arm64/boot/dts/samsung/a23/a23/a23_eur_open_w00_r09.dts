#if 1
&tlmm {
	btp_ldo_en: btp_ldo_en {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,96, FUNC_OUTPUT_LOW, PULL_NONE, DRV_LV1);
	};
};
#endif

&tlmm {
	btp_irq: btp-irq {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,102, FUNC_INPUT_WAKEUP, PULL_NONE, DRV_LV3);
	};
	btp_irq_sleep: btp-irq-sleep {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,102, FUNC_INPUT, PULL_DOWN, DRV_LV3);
	};
};

&tlmm {
	btp_sleep: btp_sleep_enable {
		GPIO_CONFIG_PUD_DRV(AP,tlmm,103, FUNC_OUTPUT_LOW, PULL_DOWN, DRV_LV1);
	};
};

#if 0
&${fps_regul_vdd_3p3} {
	regulator-name = "VDD_BTP_3P3";
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
	qcom,init-voltage = <3300000>;
};
#endif

#if defined(CONFIG_SEC_FACTORY) || !1
&qupv3_se5_spi {
	status = "okay";
#else
&smd {
#endif
	#address-cells = <1>;
	#size-cells = <0>;

	etspi-spi@0 {
		compatible = "etspi,et5xx";
		reg = <0x00>;
		spi-max-frequency = <12500000>;

		pinctrl-names = "default", "pins_poweron", "pins_poweroff"
						, "pins_poweron_tz", "pins_poweroff_tz";
#if 1
		pinctrl-0 = <&btp_sleep &btp_irq &btp_ldo_en>;
#else
		pinctrl-0 = <&btp_sleep &btp_irq>;
#endif
		pinctrl-1 = <&btp_irq>;
		pinctrl-2 = <&btp_irq_sleep>;
		pinctrl-3 = <&btp_irq>;
		pinctrl-4 = <&btp_irq_sleep>;
		gpio-controller;
		#gpio-cells = <2>;
#if 1
		etspi-ldoPin = <SEC_GPIO_REF(AP,tlmm,96) 0>;
#endif
#if 0
		etspi-regulator = "VDD_BTP_3P3";
		VDD_BTP_3P3-supply = <&${fps_regul_vdd_3p3}>;
#endif
		etspi-sleepPin = <SEC_GPIO_REF(AP,tlmm,103) 0>;
		etspi-drdyPin = <SEC_GPIO_REF(AP,tlmm,102) 0>;
		etspi-chipid = "ET528";
		etspi-orient = <2>;
	};
