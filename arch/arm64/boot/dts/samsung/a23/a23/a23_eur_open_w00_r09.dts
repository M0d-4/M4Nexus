#define PIN_AP_FUNC_GCC_GP1		"gcc_gp1"
#define PIN_AP_FUNC_GCC_GP2		"gcc_gp2"
#define PIN_AP_FUNC_GCC_GP3		"gcc_gp3"
#define PIN_AP_FUNC_SIMPLE_GPIO		"gpio"
#define PIN_AP_FUNC_MDP_VSYNC		"mdp_vsync"
#define PIN_AP_FUNC_CAM_MCLK		"cam_mclk"

#define	PIN_AP_FUNC_QUP0	"qup0"
#define	PIN_AP_FUNC_QUP1	"qup1"
