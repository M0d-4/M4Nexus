&pm6125_vadc {
	bat_thm { /* AMUX_2 */
		label = "bat_thm";
		reg = <ADC_AMUX_THM2_PU2>;
		qcom,pre-scaling = <1 1>;
		qcom,hw-settle-time = <200>;
		qcom,ratiometric;
		qcom,scale-fn-type = <ADC_SCALE_HW_CALIB_DEFAULT>;
	};
};

