	fragment@103 {
		target = <0xffffffff>;

		__overlay__ {

			usb-notifier {
				compatible = "samsung,usb-notifier";
				qcom,disable_control_en = <0x1>;
				qcom,unsupport_host_en = <0x0>;
				phandle = <0xbb>;
			};
		};
	};

	fragment@104 {
		target = <0xffffffff>;

		__overlay__ {

			argos {
				compatible = "samsung,argos";
				#address-cells = <0x1>;

				boot_device@1 {
					net_boost,label = "WIFI TX";
					net_boost,node = "wlan0";
					net_boost,table_size = <0x1>;
					net_boost,table = <0xc8 0x21b100 0x0 0x21b100 0x0 0x0 0x0 0x0 0x0 0x0>;
				};

				boot_device@2 {
					net_boost,label = "WIFI RX";
					net_boost,node = "wlan0";
					net_boost,table_size = <0x1>;
					net_boost,table = <0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0>;
				};

				boot_device@3 {
					net_boost,label = "SWLAN";
					net_boost,node = "swlan0";
					net_boost,table_size = <0x1>;
					net_boost,table = <0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0>;
				};

				boot_device@4 {
					net_boost,label = "UFS";
					net_boost,node = [00];
					net_boost,sysnode = "/sys/class/sec/ufs/transferred_cnt";
					net_boost,table_size = <0x1>;
					net_boost,table = <0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0>;
				};

				boot_device@5 {
					net_boost,label = "P2P";
					net_boost,node = "p2p-wlan0-0";
					net_boost,table_size = <0x1>;
					net_boost,table = <0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0>;
				};

				boot_device@6 {
					net_boost,label = "NAN";
					net_boost,node = "aware_data0";
					net_boost,table_size = <0x1>;
					net_boost,table = <0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0>;
				};

				boot_device@7 {
					net_boost,label = "IPC";
					net_boost,node = "rmnet_mhi0";
					net_boost,table_size = <0x1>;
					net_boost,table = <0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0>;
				};
			};
		};
	};

	fragment@105 {
		target = <0xffffffff>;

		__overlay__ {

			sec_smem@0 {
				compatible = "samsung,sec-smem";
				status = "okay";
			};

			qcom,memshare {
				compatible = "qcom,memshare";

				qcom,client_4 {
					compatible = "qcom,memshare-peripheral";
					memory-region = <0x5d>;
					qcom,peripheral-size = <0x2000000>;
					qcom,reserved-size = <0x4000000>;
					qcom,client-id = <0x3>;
					qcom,allocate-boot-time;
					label = "modem";
				};
			};

			samsung,sec_misc {
				qfprom_jtag,reg = <0x1b44180>;
			};

			samsung,sec_hdm {
				memory-region = <0x5e>;
			};
		};
	};

