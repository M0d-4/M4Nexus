	fragment@149 {
		target = <0xffffffff>;

		__overlay__ {

			rcam1_mclk_active {
				phandle = <0x73>;

				mux {
					pins = "gpio20";
					function = "cam_mclk";
				};

				config {
					pins = "gpio20";
					bias-disable;
					drive-strength = <0x4>;
				};
			};

			rcam1_mclk_suspend {
				phandle = <0x75>;

				mux {
					pins = "gpio20";
					function = "cam_mclk";
				};

				config {
					pins = "gpio20";
					bias-pull-down;
					drive-strength = <0x4>;
					output-low;
				};
			};

			rcam1_rst_active {
