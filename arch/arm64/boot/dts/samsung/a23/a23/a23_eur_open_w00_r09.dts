#if 0
	qcom,panel-sec-supply-entries
#else
	qcom,panel-supply-entries
#endif
	{
		#address-cells = <1>;
		#size-cells = <0>;

		/* display on: 1.8V -> 3ms -> 5.5V -> 3ms -> -5.5V -> 10ms
		 * -> reset high -> 3ms-> reset low -> 1ms -> reset high
		 * -> 10ms -> display config1 ->  sleep out -> 120ms
		 * -> display on -> 40ms -> backlight on
		 */
		/* display off: backlight off -> 10ms -> display off -> 20ms
		 * -> sleep in -> 70ms -> reset low -> 3ms -> -5.5V -> 1ms
		 * -> 5.5V -> 3ms ->  vddi off
		 */
		qcom,panel-supply-entry@0 {
			reg = <0>;
			qcom,supply-name = "lcd_vddi"; /* VDD 1.8V */
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <3>;
			qcom,supply-post-off-sleep = <32>;
		};

		qcom,panel-supply-entry@1 {
			reg = <1>;
			qcom,supply-name = "lcd_vsp";
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <5>;
			qcom,supply-post-off-sleep = <5>;
		};
		qcom,panel-supply-entry@2 {
			reg = <2>;
			qcom,supply-name = "lcd_vsn";
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
			qcom,supply-post-on-sleep = <10>;
			qcom,supply-post-off-sleep = <3>;
		};

#if 1
		qcom,panel-supply-entry@4 {
			reg = <4>;
			qcom,supply-name = "lcd_rst";
			qcom,supply-min-voltage = <1800000>;
			qcom,supply-max-voltage = <1800000>;
			qcom,supply-enable-load = <100000>;
			qcom,supply-disable-load = <100>;
			qcom,supply-pre-on-sleep = <0>; /* unit is ms*/
