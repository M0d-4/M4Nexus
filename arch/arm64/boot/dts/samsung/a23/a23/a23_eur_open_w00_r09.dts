				};

				config {
					pins = "gpio28";
					bias-pull-down;
					drive-strength = <0x4>;
					output-low;
				};
			};

			fcam_mclk_active {
				phandle = <0x7a>;

				mux {
					pins = "gpio27";
					function = "cam_mclk";
				};

				config {
					pins = "gpio27";
					bias-disable;
					drive-strength = <0x4>;
				};
			};

			fcam_mclk_suspend {
				phandle = <0x7b>;

				mux {
					pins = "gpio27";
					function = "cam_mclk";
				};

				config {
					pins = "gpio27";
					bias-pull-down;
					drive-strength = <0x4>;
					output-low;
				};
			};

			cam_torch_active {
				phandle = <0x6a>;

				mux {
					pins = "gpio86";
