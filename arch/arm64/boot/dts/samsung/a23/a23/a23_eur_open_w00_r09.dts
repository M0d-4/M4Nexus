#define	PIN_AP_FUNC_QUP13	"qup13"
#define	PIN_AP_FUNC_QUP14	"qup14"
#define	PIN_AP_FUNC_QUP15	"qup15"
#define	PIN_AP_FUNC_QUP16	"qup16"
#define	PIN_AP_FUNC_QUP17	"qup17"
