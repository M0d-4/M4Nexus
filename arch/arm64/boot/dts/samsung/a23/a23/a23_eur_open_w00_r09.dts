#include <dt-bindings/interrupt-controller/arm-gic.h>
#include "../../../vendor/qcom/khaje-idp-nopmi.dtsi"


/* #include "../../abc_common.dtsi" */               /* From abc_common.py */
&smd {
	abc_hub {
		compatible = "samsung,abc_hub";
		status = "okay";
		bootc {
			bootc,time_spec_user = <100000>; /* user binary user build */
			bootc,time_spec_eng = <150000>; /* user binary eng build */
			bootc,time_spec_fac = <100000>; /* factory binary */
		};
	};
};

/* #include "../../i2c-gpio-1.dtsi" */               /* From i2c-gpio.py */
&tlmm {
       gpio_i2c_1_sda {
               gpio_i2c_1_sda_default: gpio_i2c_1_sda_default {
                       GPIO_CONFIG_PUD_DRV(AP,tlmm,83, FUNC_INPUT, PULL_NONE, DRV_LV1);
               };
       };
};

&tlmm {
       gpio_i2c_1_scl {
               gpio_i2c_1_scl_default: gpio_i2c_1_scl_default {
                       GPIO_CONFIG_PUD_DRV(AP,tlmm,84, FUNC_INPUT, PULL_NONE, DRV_LV1);
               };
       };
};

/ {
	fragment@model {
		target-path = "/";
	        __overlay__ {
			aliases {
				  i2c31 = "/i2c@31";
			};
			/* Software I2C */
			sw_i2c1: i2c@31 {
				cell-index = <31>;
				compatible = "i2c-gpio";
				gpios = <
					SEC_GPIO_REF(AP,tlmm,83) 0 /* SDA */
					SEC_GPIO_REF(AP,tlmm,84) 0 /* SCL */
					>;
				#i2c-gpio,delay-us = <2>;
				#address-cells = <1>;
				#size-cells = <0>;

				pinctrl-names = "default";
				pinctrl-0 = <
					&gpio_i2c_1_sda_default
					&gpio_i2c_1_scl_default
					>;

=======
/dts-v1/;

/ {
	model = "Samsung A23 PROJECT (board-id,09)";
	compatible = "qcom,khaje-idp", "qcom,khaje:qcom,idp";
	qcom,msm-id = <0x206 0x10000>;
	qcom,board-id = <0x10022 0x9>;
	qcom,pmic-id = <0x2d 0x0 0x0 0x0>;
	dtbo-version = <0x0>;
	dtbo-hw_rev = <0x9>;
	dtbo-hw_rev_end = <0x20>;

	fragment@smd {
		target-path = [2f 00];

		__overlay__ {

			samsung_mobile_device {
				compatible = "simple-bus";
				#address-cells = <0x1>;
				#size-cells = <0x0>;
				phandle = <0x84>;

				input_booster {
					status = "okay";
					compatible = "input_booster";
					resValcount = [32 00];
					max_resource_count = [34 00];
					max_cluster_count = [33 00];
					#address-cells = <0x1>;
					#size-cells = <0x0>;
					cpu_cluster_policy = "4,0";
					ib_release_values = "-1,0,-2,0";
					allowed_resources = "0,1,2,3";

					booster_key@1 {
						input_booster,label = "key";
						input_booster,type = <0x0>;
						input_booster,head_time = <0x1f4>;
						input_booster,tail_time = <0x1f4>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0x0>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x0>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@2 {
						input_booster,label = "touchkey";
						input_booster,type = <0x1>;
						input_booster,head_time = <0x0>;
						input_booster,tail_time = <0x1f4>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0x0>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x0>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@3 {
						input_booster,label = "touch";
						input_booster,type = <0x2>;
						input_booster,head_time = <0xc8>;
						input_booster,tail_time = <0x12c>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0xfd200>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x3f9 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x2>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x5 0x5>;
							};
						};
					};

					booster_key@4 {
						input_booster,label = "multitouch";
						input_booster,type = <0x3>;
						input_booster,head_time = <0xc8>;
						input_booster,tail_time = <0x320>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x1af400 0x148200>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x2>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@5 {
						input_booster,label = "keyboard";
						input_booster,type = <0x4>;
						input_booster,head_time = <0x82>;
						input_booster,tail_time = <0x0>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0x148200>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x2>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@6 {
						input_booster,label = "mouse";
						input_booster,type = <0x5>;
						input_booster,head_time = <0xc8>;
						input_booster,tail_time = <0x12c>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0x77880>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x0>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@7 {
						input_booster,label = "mouse_wheel";
						input_booster,type = <0x6>;
						input_booster,head_time = <0xc8>;
						input_booster,tail_time = <0x0>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0x0>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x0>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@8 {
						input_booster,label = "pen_hover";
						input_booster,type = <0x7>;
						input_booster,head_time = <0xc8>;
						input_booster,tail_time = <0x12c>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x148200 0x77880>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x0>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x0 0x0>;
							};
						};
					};

					booster_key@9 {
						input_booster,label = "pen";
						input_booster,type = <0x8>;
						input_booster,head_time = <0xc8>;
						input_booster,tail_time = <0x258>;

						inputbooster,resource {
							compatible = "resource";

							resource@1 {
								resource,label = "CPU";
								resource,value = <0x1af400 0x101d00>;
							};

							resource@2 {
								resource,label = "DDR";
								resource,value = <0x0 0x0>;
							};

							resource@3 {
								resource,label = "HMP";
								resource,value = <0x2 0x2>;
							};

							resource@4 {
								resource,label = "LPM";
								resource,value = <0x5 0x5>;
							};
						};
					};
				};

				sec_abc {
					compatible = "samsung,sec_abc";
					status = "okay";

					abc_spec_type1 {
						module_list = "gpu", "gpu_qc", "gpu_qc", "camera", "camera", "vib";
						name_list = "gpu_fault", "gpu_fault", "gpu_page_fault", "mipi_overflow", "i2c_fail", "int_gnd_short";
						threshold_cnt = <0x14 0x2 0x14 0x1 0x1 0x19>;
						threshold_time = <0x4b0 0x4b0 0x4b0 0x0 0x0 0x5>;
					};
				};

				abc_hub {
					compatible = "samsung,abc_hub";
					status = "okay";

					bootc {
						bootc,time_spec_user = <0x186a0>;
						bootc,time_spec_eng = <0x249f0>;
						bootc,time_spec_fac = <0x186a0>;
					};
				};

				etspi-spi@0 {
					compatible = "etspi,et5xx";
					reg = <0x0>;
					spi-max-frequency = <0xbebc20>;
					pinctrl-names = "default", "pins_poweron", "pins_poweroff", "pins_poweron_tz", "pins_poweroff_tz";
					pinctrl-0 = <0x1 0x2 0x3>;
					pinctrl-1 = <0x2>;
					pinctrl-2 = <0x4>;
					pinctrl-3 = <0x2>;
					pinctrl-4 = <0x4>;
					gpio-controller;
					#gpio-cells = <0x2>;
					etspi-ldoPin = <0xffffffff 0x60 0x0>;
					etspi-sleepPin = <0xffffffff 0x67 0x0>;
					etspi-drdyPin = <0xffffffff 0x66 0x0>;
					etspi-chipid = "ET528";
					etspi-orient = <0x2>;
				};

				fixed_regulator@1 {
					compatible = "regulator-fixed";
					regulator-name = "lcd_vsp";
					gpio = <0xffffffff 0x30 0x0>;
					pinctrl-names = "default";
					pinctrl-0 = <0x5>;
					enable-active-high;
					regulator-boot-on;
					phandle = <0x85>;
				};

				fixed_regulator@4 {
					compatible = "regulator-fixed";
					regulator-name = "fixed_regulator4";
					gpio = <0xffffffff 0x1f 0x0>;
					pinctrl-names = "default";
					pinctrl-0 = <0x6>;
					enable-active-high;
					phandle = <0x58>;
				};

				fixed_regulator@2 {
					compatible = "regulator-fixed";
					regulator-name = "lcd_vsn";
					gpio = <0xffffffff 0x31 0x0>;
					pinctrl-names = "default";
					pinctrl-0 = <0x7>;
					enable-active-high;
					regulator-boot-on;
					phandle = <0x86>;
				};

				fixed_regulator@0 {
					compatible = "regulator-fixed";
					regulator-name = "lcd_vddi";
					gpio = <0xffffffff 0x2f 0x0>;
					pinctrl-names = "default";
					pinctrl-0 = <0x8>;
					enable-active-high;
					regulator-boot-on;
					phandle = <0x87>;
				};

				fixed_regulator@3 {
					compatible = "regulator-fixed";
					regulator-name = "lcd_rst";
					gpio = <0xffffffff 0x18 0x0>;
					pinctrl-names = "default";
					pinctrl-0 = <0x9>;
					enable-active-high;
					regulator-boot-on;
					phandle = <0x88>;
				};

				muic {
					new_factory;
					dcd_timeout;
				};

				battery {
					battery,fgsrc_switch_name = "s2mu106-fuelgauge";
					battery,otg_name = "s2mu106-otg";
